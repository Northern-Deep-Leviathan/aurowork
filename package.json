{
  "name": "@nld/aurowork-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "AUROWORK_DEV_MODE=1 pnpm --filter @aurowork/desktop dev",
    "dev:windows": "scripts/dev-windows.cmd",
    "dev:ui": "AUROWORK_DEV_MODE=1 pnpm --filter @aurowork/app dev",
    "dev:story": "AUROWORK_DEV_MODE=1 pnpm --filter @aurowork/story-book dev",
    "dev:web": "AUROWORK_DEV_MODE=1 pnpm --filter @aurowork-ee/den-web dev",
    "dev:web-local": "AUROWORK_DEV_MODE=1 bash scripts/dev-web-local.sh",
    "dev:den-docker": "bash packaging/docker/den-dev-up.sh",
    "dev:headless-web": "AUROWORK_DEV_MODE=1 bun scripts/dev-headless-web.ts",
    "build": "node scripts/build.mjs",
    "build:ui": "pnpm --filter @aurowork/app build",
    "build:web": "pnpm --filter @aurowork-ee/den-web build",
    "format:files:check": "prettier --check",
    "format:files:fix": "prettier --write",
    "preview": "pnpm --filter @aurowork/app preview",
    "typecheck": "pnpm --filter @aurowork/app typecheck",
    "test:health": "pnpm --filter @aurowork/app test:health",
    "test:sessions": "pnpm --filter @aurowork/app test:sessions",
    "test:refactor": "pnpm --filter @aurowork/app test:refactor",
    "test:events": "pnpm --filter @aurowork/app test:events",
    "test:todos": "pnpm --filter @aurowork/app test:todos",
    "test:permissions": "pnpm --filter @aurowork/app test:permissions",
    "test:session-scope": "pnpm --filter @aurowork/app test:session-scope",
    "test:session-switch": "pnpm --filter @aurowork/app test:session-switch",
    "test:fs-engine": "pnpm --filter @aurowork/app test:fs-engine",
    "test:e2e": "pnpm --filter @aurowork/app test:e2e",
    "test:orchestrator": "pnpm --filter aurowork-orchestrator test:router",
    "bump:patch": "pnpm --filter @aurowork/app bump:patch",
    "bump:minor": "pnpm --filter @aurowork/app bump:minor",
    "bump:major": "pnpm --filter @aurowork/app bump:major",
    "bump:set": "pnpm --filter @aurowork/app bump:set",
    "release:review": "node scripts/release/review.mjs",
    "release:prepare": "node scripts/release/prepare.mjs",
    "release:prepare:dry": "node scripts/release/prepare.mjs --dry-run",
    "release:ship": "node scripts/release/ship.mjs",
    "release:ship:watch": "node scripts/release/ship.mjs --watch",
    "tauri": "pnpm --filter @aurowork/desktop exec tauri"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@whiskeysockets/baileys",
      "better-sqlite3",
      "esbuild",
      "protobufjs"
    ],
    "patchedDependencies": {
      "@solidjs/router@0.15.4": "patches/@solidjs__router@0.15.4.patch"
    }
  },
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
