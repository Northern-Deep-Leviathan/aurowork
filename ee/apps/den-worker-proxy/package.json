{
  "name": "@aurowork-ee/den-worker-proxy",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:den-db && AUROWORK_DEV_MODE=1 tsx watch src/server.ts",
    "build": "npm run build:den-db && tsc -p tsconfig.json",
    "build:den-db": "pnpm --filter @aurowork-ee/den-db build",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@aurowork-ee/den-db": "workspace:*",
    "@aurowork-ee/utils": "workspace:*",
    "@daytonaio/sdk": "^0.150.0",
    "@hono/node-server": "^1.13.8",
    "dotenv": "^16.4.5",
    "hono": "^4.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.15.7",
    "typescript": "^5.5.4"
  }
}
