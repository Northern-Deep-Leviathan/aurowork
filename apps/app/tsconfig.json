{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "noLib": false,            // Keeps the basic JS library types (like Array, String)
    "maxNodeModuleJsDepth": 0  // Prevents tsc from searching inside node_modules
  },
  "include": ["src", "vite.config.ts"],
  "exclude": [
    "node_modules"             // Explicitly tells tsc not to look in this folder
  ]
}
